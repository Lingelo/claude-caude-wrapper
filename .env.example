# Proxy Server Configuration

# Auth0 Configuration
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://claude-proxy.corp.example.com/api

# Role-based API Key Mapping (path to JSON file or inline JSON)
# Example file content:
# {
#   "role_keys": {
#     "developer":  { "api_key": "sk-ant-...", "description": "Standard quota" },
#     "tech-lead":  { "api_key": "sk-ant-...", "description": "High quota" },
#     "po":         { "api_key": "sk-ant-...", "description": "Limited quota" },
#     "default":    { "api_key": "sk-ant-...", "description": "Fallback" }
#   }
# }
ROLE_KEYS_CONFIG=./role-keys.json

# Server
PORT=8080
HOST=0.0.0.0

# Database
DATABASE_PATH=./data/usage.db

# Rate Limiting (requests per minute per user)
RATE_LIMIT_RPM=60

# Logging
LOG_LEVEL=info

# Upstream Anthropic URL (override for testing)
ANTHROPIC_UPSTREAM_URL=https://api.anthropic.com

# --- CLI Configuration ---
# These are set in ~/.claude-enterprise/config.json by the CLI
# AUTH0_CLIENT_ID=your-auth0-client-id
# PROXY_URL=https://proxy.corp.example.com
